#!/bin/sh

# Block pushes that contain blobs larger than 100MB (GitHub hard limit).
limit=104857600
zero=0000000000000000000000000000000000000000
status=0

while read local_ref local_sha remote_ref remote_sha
do
  if [ -z "$local_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero" ] || [ -z "$remote_sha" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  bad="$(git rev-list --objects "$range" | git cat-file --batch-check='%(objecttype) %(objectname) %(objectsize) %(rest)' | awk -v l="$limit" '$1=="blob" && $3>l {print}')"
  if [ -n "$bad" ]; then
    echo "Push blocked: files larger than 100MB detected:"
    echo "$bad"
    status=1
  fi
done

exit "$status"

